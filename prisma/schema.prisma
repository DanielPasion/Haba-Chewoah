// Haba-Chewoah · Prisma schema
// Mirrors .claude/db/schema.dbml + 001_init.sql.
// Read .claude/db/NOTES.md for cascades, enum enforcement, polymorphic
// reports cleanup, timezone handling, streaks, blocks, etc.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum FrequencyType {
  daily
  weekly
  n_per_period

  @@map("frequency_type")
}

enum HabitStatus {
  active
  succeeded
  failed
  abandoned

  @@map("habit_status")
}

enum ReportTargetType {
  user
  comment
  habit_log

  @@map("report_target_type")
}

enum ReportStatus {
  pending
  reviewed
  dismissed

  @@map("report_status")
}

enum NotificationType {
  follow
  like
  comment
  // `mention` — author of a comment @-tagged you. Distinct from `comment`
  // so a single comment that both lands on your log AND mentions you only
  // surfaces once (the comment-on-own-log fanout suppresses the mention).
  mention
  // `chewout` — a follower hit "chew out" on your active habit before
  // end-of-day. Cooldown enforced by the `chewouts` table, not here.
  chewout
  // `follow_log` — a user you follow added a new log on a public habit.
  // habitId + habitLogId are both set; localDay stays NULL (user-action
  // notif). Private/archived habits do NOT fan this out.
  follow_log
  // System-fired (cron). actor_id is NULL on these.
  reminder
  streak_at_risk
  streak_milestone
  habit_succeeded

  @@map("notification_type")
}

enum DevicePlatform {
  ios
  android
  web

  @@map("device_platform")
}

enum MediaType {
  photo
  video

  @@map("media_type")
}

// ============================================================
// USERS + NEXTAUTH (Discord OAuth only)
//
// Per design (.claude/db/schema.dbml): users.discord_id is the immutable
// auth-only identity (NOT NULL UNIQUE), users.username is the user-chosen
// public handle and is NULL until the user completes /create-account.
// `username IS NULL` is the canonical "needs onboarding" signal — no
// boolean flag duplicates this state.
//
// Auth-required exceptions (NOT in design canon, kept because NextAuth's
// PrismaAdapter requires them):
//   - User.name / email / emailVerified / image (auth shell, populated
//     from Discord profile)
//   - Account / Session / VerificationToken tables
// `image` is mapped to the design column `avatar_url`.
//
// `discordId` is set during the Discord provider's `profile()` callback
// so the very first INSERT satisfies NOT NULL — see src/server/auth/config.ts.
// ============================================================

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String?
  email         String?   @unique
  emailVerified DateTime? @db.Timestamptz
  image         String?   @map("avatar_url")

  discordId String   @unique @map("discord_id")
  username  String?  @unique
  // Every prior `username` this user has held, lowercased. When somebody
  // visits /profile/<old-handle>, the page falls back to this list to
  // redirect to the current handle so old share-links and push-notification
  // URLs don't 404 after a rename. A *new* user later claiming the old
  // handle still wins the primary lookup; the fallback only runs when no
  // user currently owns the requested name.
  previousUsernames String[] @default([]) @map("previous_usernames")
  bio       String?
  timezone  String   @default("UTC")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  accounts Account[]
  sessions Session[]

  habits                 Habit[]
  habitLogs              HabitLog[]
  followers              Follow[]       @relation("Following")
  following              Follow[]       @relation("Follower")
  blockers               Block[]        @relation("Blocked")
  blocking               Block[]        @relation("Blocker")
  reports                Report[]
  likes                  Like[]
  comments               Comment[]
  notifications          Notification[] @relation("Recipient")
  triggeredNotifications Notification[] @relation("Actor")
  deviceTokens           DeviceToken[]
  pushSubscriptions      PushSubscription[]
  chewoutsSent           Chewout[]      @relation("ChewoutSender")
  chewoutsReceived       Chewout[]      @relation("ChewoutRecipient")

  @@index([discordId])
  @@index([username])
  @@map("users")
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String  @db.Uuid
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamptz
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz

  @@unique([identifier, token])
}

// ============================================================
// HABITS
// ============================================================

model Habit {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  icon        String?
  color       String?

  frequencyType FrequencyType @map("frequency_type")
  targetCount   Int           @default(1) @map("target_count")
  periodDays    Int?          @map("period_days")

  startDate           DateTime?   @map("start_date") @db.Date
  endDate             DateTime?   @map("end_date") @db.Date
  requiredCompletions Int?        @map("required_completions")
  status              HabitStatus @default(active)

  isPublic  Boolean  @default(true) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  schedules     HabitSchedule[]
  logs          HabitLog[]
  notifications Notification[]
  chewouts      Chewout[]

  @@index([userId])
  @@index([userId, status])
  @@map("habits")
}

model HabitSchedule {
  id              String    @id @default(uuid()) @db.Uuid
  habitId         String    @map("habit_id") @db.Uuid
  habit           Habit     @relation(fields: [habitId], references: [id], onDelete: Cascade)
  dayOfWeek       Int?      @map("day_of_week")
  reminderTime    DateTime? @map("reminder_time") @db.Time
  reminderEnabled Boolean   @default(true) @map("reminder_enabled")

  @@index([habitId])
  @@map("habit_schedules")
}

model HabitLog {
  id          String   @id @default(uuid()) @db.Uuid
  habitId     String   @map("habit_id") @db.Uuid
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  completedAt DateTime @map("completed_at") @db.Timestamptz
  notes       String?

  // Optional photo/video attachment stored in R2. `mediaUrl` is the public
  // URL; the object key is derived from it for cleanup. `mediaDurationMs`
  // is required for video (capped at 15_000 by app + DB CHECK) and null
  // for photo. See .claude/db/NOTES.md §17.
  mediaUrl        String?    @map("media_url")
  mediaType       MediaType? @map("media_type")
  mediaDurationMs Int?       @map("media_duration_ms")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  likes         Like[]
  comments      Comment[]
  notifications Notification[]

  @@index([habitId])
  @@index([userId])
  @@index([userId, completedAt])
  @@index([habitId, completedAt])
  @@map("habit_logs")
}

// ============================================================
// SOCIAL
// ============================================================

model Follow {
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

model Block {
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

// reports.targetId is polymorphic — no FK. Cleanup job required (see NOTES.md §3).
model Report {
  id         String           @id @default(uuid()) @db.Uuid
  reporterId String           @map("reporter_id") @db.Uuid
  reporter   User             @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  targetType ReportTargetType @map("target_type")
  targetId   String           @map("target_id") @db.Uuid
  reason     String
  status     ReportStatus     @default(pending)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz

  @@index([targetType, targetId])
  @@index([status])
  @@map("reports")
}

model Like {
  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitLogId String   @map("habit_log_id") @db.Uuid
  habitLog   HabitLog @relation(fields: [habitLogId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@id([userId, habitLogId])
  @@index([habitLogId])
  @@map("likes")
}

model Comment {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitLogId String   @map("habit_log_id") @db.Uuid
  habitLog   HabitLog @relation(fields: [habitLogId], references: [id], onDelete: Cascade)
  content    String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  notifications Notification[]

  @@index([habitLogId])
  @@index([userId])
  @@map("comments")
}

// ============================================================
// NOTIFICATIONS + PUSH
// ============================================================

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @map("user_id") @db.Uuid
  user       User             @relation("Recipient", fields: [userId], references: [id], onDelete: Cascade)
  actorId    String?          @map("actor_id") @db.Uuid
  actor      User?            @relation("Actor", fields: [actorId], references: [id], onDelete: Cascade)
  type       NotificationType
  // `habitId` is the habit this notification is *about* — set on chewout,
  // reminder, streak_*, habit_succeeded. Likes/comments/mentions/follows
  // leave it null (those scope by habitLogId or actorId instead).
  habitId    String?          @map("habit_id") @db.Uuid
  habit      Habit?           @relation(fields: [habitId], references: [id], onDelete: Cascade)
  habitLogId String?          @map("habit_log_id") @db.Uuid
  habitLog   HabitLog?        @relation(fields: [habitLogId], references: [id], onDelete: Cascade)
  commentId  String?          @map("comment_id") @db.Uuid
  comment    Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  isRead     Boolean          @default(false) @map("is_read")
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz

  // `localDay` is the recipient's local YMD on which this notification was
  // fired — set ONLY for cron-fired system notifications (reminder,
  // streak_at_risk, streak_milestone, habit_succeeded). The unique below
  // backstops the cron's check-then-insert dedup so concurrent runs can't
  // produce duplicates. NULL on user-action notifs (like/comment/mention/
  // follow/chewout); Postgres treats NULLs as distinct, so those aren't
  // affected by the unique.
  localDay   DateTime?        @map("local_day") @db.Date

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  // Cron jobs check "did we already fire this type for this habit today?"
  // before inserting a new system notification — this index keeps that
  // dedup query cheap.
  @@index([userId, type, habitId, createdAt])
  // Race-safe dedup for cron-fired notifs. Concurrent cron runs racing
  // through `findFirst → create` both observe "no fire today" and both
  // try to insert; the second hits this constraint and is treated as
  // idempotent success at the call site.
  @@unique([userId, habitId, type, localDay])
  @@map("notifications")
}

model DeviceToken {
  token      String         @id
  userId     String         @map("user_id") @db.Uuid
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform   DevicePlatform
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz
  lastUsedAt DateTime?      @map("last_used_at") @db.Timestamptz

  @@index([userId])
  @@map("device_tokens")
}

// Web Push (VAPID) subscription. Distinct from `DeviceToken` because the
// browser push protocol identifies a recipient by the endpoint URL plus a
// pair of keys, not a single opaque string. iOS/Android (APNs/FCM) keep
// using `DeviceToken` when wired up.
model PushSubscription {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz

  @@index([userId])
  @@map("push_subscriptions")
}

// "Chew-out" — a follower pings another user about an unfinished active
// habit. One chew-out per (sender, recipient, habit, day) — `day` is the
// recipient's local YMD so timezones don't reset cooldowns mid-evening.
//
// The notification fanout uses this row's existence to enforce dedup; the
// notification itself lives in the `notifications` table with type=chewout.
model Chewout {
  id          String   @id @default(uuid()) @db.Uuid
  senderId    String   @map("sender_id") @db.Uuid
  sender      User     @relation("ChewoutSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String   @map("recipient_id") @db.Uuid
  recipient   User     @relation("ChewoutRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  habitId     String   @map("habit_id") @db.Uuid
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  day         DateTime @db.Date
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([senderId, recipientId, habitId, day])
  @@index([recipientId, day])
  @@map("chewouts")
}
