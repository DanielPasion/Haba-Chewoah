# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Next Auth
# You can generate a new secret on the command line with:
# npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET=""

# Next Auth Discord Provider
# Get these at https://discord.com/developers/applications → your app → OAuth2.
# Register these redirect URLs on the same OAuth2 page → Redirects:
#   Local dev: http://localhost:3000/api/auth/callback/discord
#   Prod:      https://<your-domain>/api/auth/callback/discord
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Prisma · Postgres
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
# Local example: postgresql://postgres:postgres@localhost:5432/haba_chewoah
DATABASE_URL=""

# Cloudflare R2 (S3-compatible object storage for avatars + habit-log media)
# Convention: one bucket per project, named after the project — `haba-chewoah`.
# Object keys inside it already namespace per user (users/<id>/avatar/...), so a
# single bucket comfortably serves dev + prod until volume forces a split.
#
# NOTE: R2 has its own token system, separate from Cloudflare's general
# "API Tokens" (My Profile → API Tokens) and the legacy Global API Key.
# Neither of those will work here — you need an R2-specific token.
#
# ── 1. Create the bucket ───────────────────────────────────────────────
#   Cloudflare dashboard → R2 Object Storage → Create bucket → name it
#   `haba-chewoah`.
#
# ── 2. Public access for reads ─────────────────────────────────────────
#   Bucket → Settings → Public access. Either:
#     (a) enable the "r2.dev subdomain" (dev-only, ugly URL), OR
#     (b) connect a custom domain like `media.haba-chewoah.com` (prod).
#   Copy the resulting public URL (no trailing slash) into R2_PUBLIC_URL.
#
# ── 3. CORS so the browser can PUT directly ────────────────────────────
#   Bucket → Settings → CORS policy:
#     [{
#       "AllowedOrigins": ["http://localhost:3000", "https://haba-chewoah.com"],
#       "AllowedMethods": ["PUT"],
#       "AllowedHeaders": ["content-type"],
#       "MaxAgeSeconds": 3600
#     }]
#
# ── 4. R2 API token (the S3 credentials) ───────────────────────────────
#   Direct URL: https://dash.cloudflare.com/<account-id>/r2/api-tokens
#   Or: R2 Object Storage → "Manage R2 API Tokens" (top-right). If the
#   button is missing on your UI variant, look inside the `haba-chewoah`
#   bucket → Settings → there's a link out to token creation.
#
#   On the form:
#     - Token name:        haba-chewoah-app
#     - Permissions:       Object Read & Write
#     - Specify bucket(s): Apply to specific buckets only → `haba-chewoah`
#     - TTL:               Forever
#     - Create API Token
#
#   The result page shows four things — you only need two:
#     - "Access Key ID"     → R2_ACCESS_KEY_ID
#     - "Secret Access Key" → R2_SECRET_ACCESS_KEY  (shown once — copy now)
#     - Token value, jurisdiction endpoints → ignore
#
# ── 5. Account ID ──────────────────────────────────────────────────────
#   R2 Object Storage page → top-right shows "Account ID" with a copy
#   button. Or grab it from any Cloudflare URL: dash.cloudflare.com/<id>/...
#
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="haba-chewoah"
R2_PUBLIC_URL=""